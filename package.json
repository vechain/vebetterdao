{
  "name": "b3tr-monorepo",
  "private": true,
  "scripts": {
    "test": "turbo run test --",
    "build": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo build",
    "build:staging": "dotenv -v NEXT_PUBLIC_APP_ENV=solo-staging -- turbo build",
    "build:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo build",
    "dev": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo dev --",
    "dev:staging": "dotenv -v NEXT_PUBLIC_APP_ENV=solo-staging -e .env -- turbo dev --",
    "dev:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -e .env -- turbo dev:testnet --",
    "lint": "turbo lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "contracts:compile": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run compile --scope=contracts",
    "contracts:deploy": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run deploy --scope=contracts",
    "contracts:deploy:solo-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=solo-staging -- turbo run deploy --scope=contracts",
    "contracts:deploy:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run deploy:testnet --scope=contracts",
    "contracts:test": "turbo run test:hardhat --scope=contracts",
    "contracts:test:thor-solo": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run test:thor-solo --scope=contracts",
    "contracts:generate-b3tr-badge-metadata": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run generate-b3tr-badge-metadata --scope=contracts",
    "contracts:upload-b3tr-badge-metadata": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run upload-b3tr-badge-metadata --scope=contracts",
    "contracts:generate-xapp-metadata": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run generate-xapp-metadata --scope=contracts",
    "contracts:upload-xapp-metadata": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run upload-xapp-metadata --scope=contracts",
    "solo-up": "make solo-up"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "dotenv-cli": "latest",
    "prettier": "^3.2.4",
    "turbo": "^1.11.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
