{
  "name": "b3tr-monorepo",
  "private": true,
  "scripts": {
    "typecheck": "yarn workspace frontend typecheck",
    "test": "dotenv -v NEXT_PUBLIC_APP_ENV=local -e .env.example turbo run test --",
    "test:watch": "dotenv -v NEXT_PUBLIC_APP_ENV=local -e .env.example turbo run test:watch --",
    "test:coverage:solidity": "dotenv -v NEXT_PUBLIC_APP_ENV=local -v IS_TEST_COVERAGE=true -e .env.example turbo run test:coverage:solidity",
    "build": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo build --filter='!@repo/lambda'",
    "build:staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo build --filter='!@repo/lambda'",
    "build:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo build --filter='!@repo/lambda'",
    "build:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo build --filter='!@repo/lambda'",
    "build:lambda": "turbo build --filter='@repo/lambda'",
    "build:lambda:staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo build --filter='@repo/lambda'",
    "build:lambda:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo build --filter='@repo/lambda'",
    "start": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=local -e .env -- turbo start --",
    "start:staging": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -e .env -- turbo start:staging --",
    "start:testnet": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=testnet -e .env -- turbo start:testnet --",
    "start:mainnet": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -e .env -- turbo start:mainnet --",
    "dev": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=local -v ENDORSE_XAPPS=true -e .env -- turbo dev --",
    "dev:xapps-unendorsed": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=local -e .env -- turbo dev --",
    "dev:simulation": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=local -v ENDORSE_XAPPS=true -- turbo dev:simulation --",
    "dev:simulation-galactica": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=galactica-test -v ENDORSE_XAPPS=true -- turbo dev:simulation --",
    "dev:staging": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -e .env -- turbo dev:staging --",
    "dev:testnet": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=testnet -e .env -- turbo dev:testnet --",
    "dev:mainnet": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -e .env -- turbo dev:mainnet --",
    "dev:galactica-test": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=galactica-test -e .env -- turbo dev:galactica-test --",
    "chakra:typegen": "yarn workspace frontend chakra:typegen",
    "chakra:typegen:watch": "yarn workspace frontend chakra:typegen:watch",
    "lint": "turbo lint --",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "contracts:compile": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run compile --filter=@vechain/vebetterdao-contracts",
    "contracts:compile:slither": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run compile:slither --filter=@vechain/vebetterdao-contracts",
    "contracts:publish": "yarn workspace @vechain/vebetterdao-contracts publish",
    "contracts:deploy": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run deploy --filter=@vechain/vebetterdao-contracts",
    "contracts:deploy:local": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run deploy --filter=@vechain/vebetterdao-contracts",
    "contracts:deploy:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo run deploy --filter=@vechain/vebetterdao-contracts",
    "contracts:deploy:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run deploy:testnet --filter=@vechain/vebetterdao-contracts",
    "contracts:deploy:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run deploy:mainnet --filter=@vechain/vebetterdao-contracts",
    "contracts:deploy:latest": "dotenv -v NEXT_PUBLIC_APP_ENV=local -v NEXT_DEPLOY_LATEST_ONLY=true -e .env turbo run deploy --filter=@vechain/vebetterdao-contracts",
    "contracts:deploy:testnet-staging:latest": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -v NEXT_DEPLOY_LATEST_ONLY=true  -e .env turbo run deploy --filter=@vechain/vebetterdao-contracts",
    "contracts:deploy:galactica-test": "dotenv -v NEXT_PUBLIC_APP_ENV=galactica-test -- turbo run deploy:galactica-test --filter=@vechain/vebetterdao-contracts",
    "contracts:select-and-deploy": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/deploy/select-and-deploy.ts",
    "contracts:select-and-deploy:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/deploy/select-and-deploy.ts",
    "contracts:select-and-deploy:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/deploy/select-and-deploy.ts",
    "contracts:select-and-deploy:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/deploy/select-and-deploy.ts",
    "contracts:upgrade": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/upgrade/select-and-upgrade.ts",
    "contracts:setup-environment": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- yarn workspace @vechain/vebetterdao-contracts setup-environment:local",
    "contracts:upgrade:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/upgrade/select-and-upgrade.ts",
    "contracts:upgrade:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/upgrade/select-and-upgrade.ts",
    "contracts:upgrade:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/upgrade/select-and-upgrade.ts",
    "contracts:start-round:testnet": "dotenv -e .env.example -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run start-round:testnet --filter=@vechain/vebetterdao-contracts",
    "contracts:start-round:testnet-staging": "dotenv -e .env.example -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo run start-round --filter=@vechain/vebetterdao-contracts",
    "contracts:get-galaxy-member-owners": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run get-galaxy-member-owners --filter=@vechain/vebetterdao-contracts",
    "contracts:get-galaxy-member-owners:staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo run get-galaxy-member-owners:staging --filter=@vechain/vebetterdao-contracts",
    "contracts:get-galaxy-member-selected-tokens": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run get-galaxy-member-selected-tokens --filter=@vechain/vebetterdao-contracts",
    "contracts:test": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run test:hardhat --filter=@vechain/vebetterdao-contracts",
    "contracts:test:shard": "SHARD=$SHARD dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run test:hardhat:shard --filter=@vechain/vebetterdao-contracts",
    "contracts:test:thor-solo": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run test:thor-solo --filter=@vechain/vebetterdao-contracts",
    "contracts:generate-galaxy-member-metadata:ipfs-dev": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run generate-galaxy-member-metadata --filter=@vechain/vebetterdao-contracts",
    "contracts:upload-galaxy-member-metadata:ipfs-dev": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run upload-galaxy-member-metadata --filter=@vechain/vebetterdao-contracts",
    "contracts:generate-xapp-metadata:ipfs-dev": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run generate-xapp-metadata --filter=@vechain/vebetterdao-contracts",
    "contracts:upload-xapp-metadata:ipfs-dev": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run upload-xapp-metadata --filter=@vechain/vebetterdao-contracts",
    "contracts:generate-galaxy-member-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run generate-galaxy-member-metadata --filter=@vechain/vebetterdao-contracts",
    "contracts:upload-galaxy-member-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run upload-galaxy-member-metadata --filter=@vechain/vebetterdao-contracts",
    "contracts:generate-xapp-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run generate-xapp-metadata --filter=@vechain/vebetterdao-contracts",
    "contracts:upload-xapp-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run upload-xapp-metadata --filter=@vechain/vebetterdao-contracts",
    "contracts:generate-creator-nft-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run generate-creator-nft-metadata --filter=@vechain/vebetterdao-contracts",
    "contracts:upload-creator-nft-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run upload-creator-nft-metadata --filter=@vechain/vebetterdao-contracts",
    "contracts:generate-docs": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run generate-docs --filter=@vechain/vebetterdao-contracts",
    "contracts:call": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/functionCalls/select-and-call.ts",
    "contracts:call:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/functionCalls/select-and-call.ts",
    "contracts:call:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/functionCalls/select-and-call.ts",
    "contracts:call:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/functionCalls/select-and-call.ts",
    "contracts:get-app-shares": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run get-app-shares --filter=@vechain/vebetterdao-contracts",
    "solo-up": "make solo-up",
    "solo-down": "make solo-down",
    "prepare": "husky install",
    "contracts:verify:testnet": "dotenv -v VITE_APP_ENV=testnet -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/verify/verify-entrypoint.ts",
    "contracts:verify:mainnet": "dotenv -v VITE_APP_ENV=mainnet -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/verify/verify-entrypoint.ts",
    "contracts:estimate-voting-gas:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run estimate-voting-gas:mainnet --filter=@vechain/vebetterdao-contracts",
    "contracts:verify:all:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/verify/verify-all-contracts.ts",
    "contracts:verify:all:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/verify/verify-all-contracts.ts",
    "contracts:check-verification-status:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/verify/check-verification-status.ts",
    "contracts:check-verification-status:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- yarn workspace @vechain/vebetterdao-contracts ts-node scripts/verify/check-verification-status.ts",
    "contracts:endorsement-migration:fetch:local": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run endorsement-migration:fetch:local --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:fetch:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo run endorsement-migration:fetch:testnet-staging --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:fetch:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run endorsement-migration:fetch:mainnet --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:simulate:local": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run endorsement-migration:simulate:local --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:simulate:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo run endorsement-migration:simulate:testnet-staging --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:simulate:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run endorsement-migration:simulate:mainnet --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:seed:local": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run endorsement-migration:seed:local --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:seed:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo run endorsement-migration:seed:testnet-staging --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:seed:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run endorsement-migration:seed:mainnet --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:verify:local": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run endorsement-migration:verify:local --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:verify:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo run endorsement-migration:verify:testnet-staging --filter=@vechain/vebetterdao-contracts",
    "contracts:endorsement-migration:verify:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run endorsement-migration:verify:mainnet --filter=@vechain/vebetterdao-contracts"
  },
  "dependencies": {
    "dotenv-cli": "latest",
    "turbo": "^2.5.0"
  },
  "devDependencies": {
    "@datadog/browser-rum": "^5.23.0",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "dotenv": "^16.4.5",
    "hardhat": "2.19.1",
    "husky": "^8.0.0",
    "lint-staged": "12.5.0",
    "prettier": "^3.3.0",
    "@vechain/picasso": "^2.1.1"
  },
  "engines": {
    "node": "20.x.x"
  },
  "resolutions": {
    "ansi-styles": "4.3.0",
    "debug": "4.4.1",
    "chalk": "4.1.2",
    "supports-color": "8.1.1",
    "strip-ansi": "6.0.1",
    "ansi-regex": "5.0.1",
    "wrap-ansi": "7.0.0",
    "color-convert": "1.9.3",
    "color-name": "1.1.4",
    "is-arrayish": "0.2.1",
    "slice-ansi": "4.0.0",
    "color": "3.2.1",
    "color-string": "1.9.1",
    "simple-swizzle": "0.2.2",
    "elliptic": "^6.6.1",
    "parse-duration": "^2.1.3",
    "axios": "^1.11.0",
    "cookie": "^0.7.1",
    "tmp": "^0.2.4",
    "hono": "^4.10.2",
    "preact": "10.28.2",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ],
    "*.{json,html}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
