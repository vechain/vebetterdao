{
  "name": "b3tr-monorepo",
  "private": true,
  "scripts": {
    "test": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -e .env.example turbo run test --",
    "test:watch": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -e .env.example turbo run test:watch --",
    "test:coverage:solidity": "dotenv -v NEXT_PUBLIC_APP_ENV=local -v IS_TEST_COVERAGE=true -e .env.example turbo run test:coverage:solidity",
    "test:coverage:fe": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -e .env.example turbo run test:coverage:fe",
    "build": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo build",
    "build:staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo build",
    "build:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo build",
    "build:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo build",
    "start": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=local -e .env -- turbo start --",
    "start:staging": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -e .env -- turbo start:staging --",
    "start:testnet": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=testnet -e .env -- turbo start:testnet --",
    "start:mainnet": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -e .env -- turbo start:mainnet --",
    "dev": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=local -v ENDORSE_XAPPS=true -e .env -- turbo dev --",
    "dev:xapps-unendorsed": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=local -e .env -- turbo dev --",
    "dev:simulation": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=local -v RUN_SIMULATION=true -- turbo dev --",
    "dev:staging": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -e .env -- turbo dev:staging --",
    "dev:testnet": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=testnet -e .env -- turbo dev:testnet --",
    "dev:mainnet": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -e .env -- turbo dev:mainnet --",
    "dev:e2e": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=e2e -- turbo dev --",
    "lint": "turbo lint --",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "contracts:compile": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run compile --filter=contracts",
    "contracts:deploy": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run deploy --filter=contracts",
    "contracts:deploy:local": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run deploy --filter=contracts",
    "contracts:deploy:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo run deploy --filter=contracts",
    "contracts:deploy:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run deploy:testnet --filter=contracts",
    "contracts:deploy:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run deploy:mainnet --filter=contracts",
    "contracts:select-and-deploy": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- yarn workspace @repo/contracts ts-node scripts/deploy/select-and-deploy.ts",
    "contracts:select-and-deploy:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- yarn workspace @repo/contracts ts-node scripts/deploy/select-and-deploy.ts",
    "contracts:select-and-deploy:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- yarn workspace @repo/contracts ts-node scripts/deploy/select-and-deploy.ts",
    "contracts:select-and-deploy:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- yarn workspace @repo/contracts ts-node scripts/deploy/select-and-deploy.ts",
    "contracts:upgrade": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- yarn workspace @repo/contracts ts-node scripts/upgrade/select-and-upgrade.ts",
    "contracts:upgrade:testnet-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- yarn workspace @repo/contracts ts-node scripts/upgrade/select-and-upgrade.ts",
    "contracts:upgrade:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- yarn workspace @repo/contracts ts-node scripts/upgrade/select-and-upgrade.ts",
    "contracts:upgrade:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- yarn workspace @repo/contracts ts-node scripts/upgrade/select-and-upgrade.ts",
    "contracts:start-round:testnet": "dotenv -e .env.example -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run start-round:testnet --filter=contracts",
    "contracts:start-round:testnet-staging": "dotenv -e .env.example -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo run start-round --filter=contracts",
    "contracts:get-galaxy-member-owners": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run get-galaxy-member-owners --filter=contracts",
    "contracts:get-galaxy-member-owners:staging": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet-staging -- turbo run get-galaxy-member-owners:staging --filter=contracts",
    "contracts:get-galaxy-member-selected-tokens": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run get-galaxy-member-selected-tokens --filter=contracts",
    "contracts:test": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run test:hardhat --filter=contracts",
    "contracts:test:shard": "SHARD=$SHARD dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run test:hardhat:shard --filter=contracts",
    "contracts:test:thor-solo": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run test:thor-solo --filter=contracts",
    "contracts:generate-galaxy-member-metadata:ipfs-dev": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run generate-galaxy-member-metadata --filter=contracts",
    "contracts:upload-galaxy-member-metadata:ipfs-dev": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run upload-galaxy-member-metadata --filter=contracts",
    "contracts:generate-xapp-metadata:ipfs-dev": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run generate-xapp-metadata --filter=contracts",
    "contracts:upload-xapp-metadata:ipfs-dev": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run upload-xapp-metadata --filter=contracts",
    "contracts:generate-galaxy-member-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run generate-galaxy-member-metadata --filter=contracts",
    "contracts:upload-galaxy-member-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run upload-galaxy-member-metadata --filter=contracts",
    "contracts:generate-xapp-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run generate-xapp-metadata --filter=contracts",
    "contracts:upload-xapp-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run upload-xapp-metadata --filter=contracts",
    "contracts:generate-creator-nft-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run generate-creator-nft-metadata --filter=contracts",
    "contracts:upload-creator-nft-metadata:ipfs-prod": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run upload-creator-nft-metadata --filter=contracts",
    "contracts:generate-docs": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run generate-docs --filter=contracts",
    "contracts:get-app-shares": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run get-app-shares --filter=contracts",
    "solo-up": "make solo-up",
    "playwright:e2e": "dotenv -v NEXT_PUBLIC_APP_ENV=e2e -- turbo run playwright:e2e",
    "generate-translations": "dotenv -e .env -- turbo generate-translations",
    "complete-translations": "dotenv -e .env -- turbo complete-translations",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@datadog/browser-rum": "^5.23.0",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "dotenv-cli": "latest",
    "dotenv": "^16.4.5",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.0",
    "turbo": "^1.13.3"
  },
  "engines": {
    "node": "20.x.x"
  },
  "packageManager": "yarn@1.22.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ],
    "*.{json,html}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
