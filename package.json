{
  "name": "b3tr-monorepo",
  "private": true,
  "scripts": {
    "test": "dotenv -v NEXT_PUBLIC_APP_ENV=solo-staging -e .env.example turbo run test --",
    "test:watch": "dotenv -v NEXT_PUBLIC_APP_ENV=solo-staging -e .env.example turbo run test:watch --",
    "test:coverage:solidity": "dotenv -v NEXT_PUBLIC_APP_ENV=solo-staging -v IS_TEST_COVERAGE=true -e .env.example turbo run test:coverage:solidity",
    "test:coverage:fe": "dotenv -v NEXT_PUBLIC_APP_ENV=solo-staging -e .env.example turbo run test:coverage:fe",
    "build": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo build",
    "build:staging": "dotenv -v NEXT_PUBLIC_APP_ENV=solo-staging -- turbo build",
    "build:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo build",
    "build:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo build",
    "dev": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo dev --",
    "dev:simulation": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=local -v RUN_SIMULATION=true -- turbo dev --",
    "dev:staging": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=solo-staging -e .env -- turbo dev --",
    "dev:testnet": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=testnet -e .env -- turbo dev:testnet --",
    "dev:mainnet": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -e .env -- turbo dev:mainnet --",
    "dev:e2e": "yarn && dotenv -v NEXT_PUBLIC_APP_ENV=e2e -- turbo dev --",
    "lint": "turbo lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "contracts:compile": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run compile --filter=contracts",
    "contracts:deploy": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run deploy --filter=contracts",
    "contracts:deploy:solo-staging": "dotenv -v NEXT_PUBLIC_APP_ENV=solo-staging -- turbo run deploy --filter=contracts",
    "contracts:deploy:testnet": "dotenv -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run deploy:testnet --filter=contracts",
    "contracts:deploy:mainnet": "dotenv -v NEXT_PUBLIC_APP_ENV=mainnet -- turbo run deploy:mainnet --filter=contracts",
    "contracts:start-round:testnet": "dotenv -e .env.example -v NEXT_PUBLIC_APP_ENV=testnet -- turbo run start-round:testnet --filter=contracts",
    "contracts:start-round:solo-staging": "dotenv -e .env.example -v NEXT_PUBLIC_APP_ENV=solo-staging -- turbo run start-round --filter=contracts",
    "contracts:test": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run test --filter=contracts",
    "contracts:test:thor-solo": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run test:thor-solo --filter=contracts",
    "contracts:generate-galaxy-member-metadata": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run generate-galaxy-member-metadata --filter=contracts",
    "contracts:upload-galaxy-member-metadata": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run upload-galaxy-member-metadata --filter=contracts",
    "contracts:generate-xapp-metadata": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run generate-xapp-metadata --filter=contracts",
    "contracts:upload-xapp-metadata": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run upload-xapp-metadata --filter=contracts",
    "contracts:generate-docs": "dotenv -v NEXT_PUBLIC_APP_ENV=local -- turbo run generate-docs --filter=contracts",
    "solo-up": "make solo-up",
    "playwright:e2e": "dotenv -v NEXT_PUBLIC_APP_ENV=e2e -- turbo run playwright:e2e",
    "release": "turbo release"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "dotenv-cli": "latest",
    "prettier": "^3.3.0",
    "turbo": "^1.13.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
