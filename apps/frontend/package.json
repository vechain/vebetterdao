{
  "name": "frontend",
  "version": "1.30.2",
  "private": true,
  "scripts": {
    "prebuild": "yarn chakra:typegen && yarn generate:schema",
    "typecheck": "tsc --noEmit",
    "chakra:typegen": "chakra typegen src/app/theme/theme.ts",
    "chakra:typegen:watch": "chakra typegen src/app/theme/theme.ts --watch",
    "dev": "next dev --turbo",
    "dev:staging": "next dev --turbo",
    "dev:testnet": "next dev --turbo",
    "dev:mainnet": "next dev --turbo",
    "staging": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "start:staging": "next start",
    "start:testnet": "next start",
    "start:mainnet": "next start",
    "lint": "next lint",
    "clean": "rm -rf .next node_modules dist",
    "generate-translations": "ts-node ./src/scripts/translations/generateTranslations.ts",
    "complete-translations": "ts-node ./src/scripts/translations/completeTranslations.ts",
    "storybook": "NEXT_PUBLIC_APP_ENV=local storybook dev -p 6006",
    "build-storybook": "NEXT_PUBLIC_APP_ENV=staging storybook build",
    "generate:schema": "openapi-typescript https://indexer.mainnet.vechain.org/api-docs -o ./src/api/indexer/schema.d.ts"
  },
  "dependencies": {
