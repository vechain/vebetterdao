{
  "$schema": "https://turbo.build/schema.json",
  "globalDotEnv": [".env"],
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build", "@repo/contracts#compile"],
      "outputs": [".next/**", "!.next/cache/**"],
      "dotEnv": [".env.production.local", ".env.local", ".env.production", ".env"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "//#solo-up": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["//#solo-up", "@repo/contracts#check-contracts-deployment"],
      "dotEnv": [".env.development.local", ".env.local", ".env.development", ".env"]
    },
    "@repo/contracts#check-contracts-deployment": {
      "dependsOn": ["^compile", "//#solo-up"],
      "dotEnv": [".env.production.local", ".env.local", ".env.production", ".env"]
    },
    "clean": {
      "cache": false
    },
    "compile": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^deploy"]
    },
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
