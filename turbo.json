{
  "$schema": "https://turbo.build/schema.json",
  "globalDotEnv": [".env"],
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NEXT_PUBLIC_APP_ENV",
    "MNEMONIC",
    "TESTNET_STAGING_MNEMONIC",
    "NEXT_PUBLIC_DATADOG_APP_TOKEN",
    "NEXT_PUBLIC_DATADOG_CLIENT_TOKEN",
    "NEXT_PUBLIC_IPFS_PINNING_SERVICE",
    "IS_TEST_COVERAGE",
    "RUN_SIMULATION",
    "SHARD",
    "CONTRACT_TO_UPGRADE",
    "CONTRACT_VERSION"
  ],
  "pipeline": {
    "install": {
      "dependsOn": ["@repo/contracts#install", "^compile"]
    },
    "@repo/contracts#install": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "cache": false
    },
    "//#solo-up": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^setup-contracts"]
    },
    "dev:staging": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts:staging"]
    },
    "dev:testnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts:testnet"]
    },
    "dev:mainnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts:mainnet"]
    },
    "setup-contracts": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile", "@repo/contracts#check-contracts-deployment"]
    },
    "setup-contracts:staging": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile", "@repo/contracts#check-contracts-deployment:staging"]
    },
    "setup-contracts:testnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile", "@repo/contracts#check-contracts-deployment:testnet"]
    },
    "setup-contracts:mainnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile", "@repo/contracts#check-contracts-deployment:mainnet"]
    },
    "simulate-passport-score:mainnet": {},
    "@repo/config#check-or-generate-local-config": {
      "cache": false
    },
    "@repo/contracts#check-contracts-deployment": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "@repo/contracts#check-contracts-deployment:staging": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "@repo/contracts#check-contracts-deployment:testnet": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "@repo/contracts#check-contracts-deployment:mainnet": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "clean": {
      "cache": false
    },
    "compile": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "deploy": {
      "dependsOn": ["^deploy", "@repo/config#check-or-generate-local-config"]
    },
    "deploy:testnet": {
      "dependsOn": ["^deploy:testnet"]
    },
    "deploy:mainnet": {
      "dependsOn": ["^deploy:mainnet"]
    },
    "upgrade:contract": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": [],
      "cache": false
    },
    "upgrade:contract:local": {
      "dependsOn": ["upgrade:contract"]
    },
    "upgrade:contract:testnet-staging": {
      "dependsOn": ["upgrade:contract"]
    },
    "upgrade:contract:testnet": {
      "dependsOn": ["upgrade:contract"]
    },
    "upgrade:contract:mainnet": {
      "dependsOn": ["upgrade:contract"]
    },
    "start-round:testnet": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "cache": false
    },
    "start-round": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "cache": false
    },
    "test": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "test:watch": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "test:coverage:fe": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "test:coverage:solidity": {
      "cache": false,
      "dependsOn": ["^@repo/config#check-or-generate-local-config"]
    },
    "test:thor-solo": {
      "cache": false
    },
    "test:hardhat": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "test:hardhat:shard": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "generate-galaxy-member-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "upload-galaxy-member-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "generate-xapp-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "upload-xapp-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "playwright:e2e": {
      "cache": false
    },
    "generate-docs": {
      "cache": false
    },
    "generate-translations": {
      "cache": false
    },
    "complete-translations": {
      "cache": false
    }
  }
}
