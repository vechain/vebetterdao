{
  "$schema": "https://turbo.build/schema.json",
  "globalDotEnv": [
    ".env",
    ".env.config"
  ],
  "globalDependencies": [
    "**/.env.*local"
  ],
  "pipeline": {
    "build": {
      "dependsOn": [
        "@repo/contracts#compile"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "//#solo-up": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [
        "@repo/contracts#check-contracts-deployment"
      ]
    },
    "@repo/config#check-or-generate-local-config": {
      "cache": false
    },
    "@repo/contracts#check-contracts-deployment": {
      "cache": false,
      "dependsOn": [
        "^compile",
        "//#solo-up",
        "@repo/config#check-or-generate-local-config"
      ]
    },
    "clean": {
      "cache": false
    },
    "compile": {
      "cache": false
    },
    "deploy": {
      "dependsOn": [
        "^deploy"
      ]
    },
    "airdrop": {
      "cache": false,
      "dependsOn": [
        "@repo/contracts#check-contracts-deployment"
      ]
    },
    "test": {
      "cache": false,
      "dependsOn": [
        "@repo/contracts#check-contracts-deployment"
      ]
    }
  }
}
