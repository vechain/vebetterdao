{
  "$schema": "https://turbo.build/schema.json",
  "globalDotEnv": [".env"],
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NEXT_PUBLIC_APP_ENV",
    "MNEMONIC"
  ],
  "pipeline": {
    "install": {
      "dependsOn": ["@repo/contracts#install", "^compile"]
    },
    "@repo/contracts#install": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "//#solo-up": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@repo/contracts#check-contracts-deployment"]
    },
    "dev:staging": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@repo/contracts#check-contracts-deployment"]
    },
    "@repo/config#check-or-generate-local-config": {
      "cache": false
    },

    "@repo/contracts#check-contracts-deployment": {
      "cache": false,
      "dependsOn": ["^compile", "//#solo-up", "@repo/config#check-or-generate-local-config"]
    },
    "clean": {
      "cache": false
    },
    "compile": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^deploy"]
    },
    "deploy:staging": {
      "dependsOn": ["@repo/contracts#deploy:vechain_solo_staging"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["@repo/contracts#check-contracts-deployment", "test:hardhat"]
    },
    "test:thor-solo": {
      "cache": false,
      "dependsOn": ["@repo/contracts#check-contracts-deployment"]
    },
    "test:hardhat": {
      "cache": false
    } 
  }
}
