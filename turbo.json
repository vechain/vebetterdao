{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_APP_ENV",
    "MNEMONIC",
    "TESTNET_STAGING_MNEMONIC",
    "NEXT_PUBLIC_DATADOG_APP_TOKEN",
    "NEXT_PUBLIC_DATADOG_CLIENT_TOKEN",
    "NEXT_PUBLIC_IPFS_PINNING_SERVICE",
    "IS_TEST_COVERAGE",
    "ENDORSE_XAPPS",
    "DO_NOT_UPGRADE",
    "SHARD",
    "CONTRACT_TO_UPGRADE",
    "CONTRACT_TO_DEPLOY",
    "CONTRACT_VERSION",
    "FUNCTION_TO_CALL",
    "NEXT_DEPLOY_LATEST_ONLY",
    "OPENAI_API_KEY",
    "RESET_USER_SIGNAL_COUNT_API_KEY",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "FRESHDESK_API_TOKEN",
    "FRESHDESK_DOMAIN",
    "FRESHDESK_GROUP_ID",
    "NEXTAUTH_SECRET",
    "TWITTER_CLIENT_ID",
    "TWITTER_CLIENT_SECRET",
    "RESET_USER_SIGNAL_COUNT_DOMAIN",
    "DISCORD_CLIENT_ID",
    "DISCORD_CLIENT_SECRET"
  ],
  "tasks": {
    "prepare-contracts": {
      "cache": true,
      "dependsOn": ["@vechain/vebetterdao-contracts#build"],
      "outputs": [
        "packages/contracts/artifacts/**",
        "packages/contracts/typechain-types/**",
        "packages/contracts/dist/**"
      ]
    },
    "build": {
      "cache": true,
      "dependsOn": ["prepare-contracts"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "src/api/indexer/schema.d.ts"]
    },
    "@vechain/vebetterdao-contracts#build": {
      "cache": true,
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": ["dist/**", "artifacts/**", "typechain-types/**", "cache/**"]
    },
    "lint": {
      "cache": false
    },
    "//#solo-up": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts"]
    },
    "dev:staging": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts:staging"]
    },
    "dev:testnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts:testnet"]
    },
    "dev:mainnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts:mainnet"]
    },
    "dev:simulation": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@vechain/vebetterdao-contracts#simulation"]
    },
    "start": {
      "cache": false,
      "dependsOn": ["^setup-contracts"]
    },
    "start:staging": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts:staging"]
    },
    "start:testnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts:testnet"]
    },
    "start:mainnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts:mainnet"]
    },
    "setup-contracts": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile", "@vechain/vebetterdao-contracts#check-contracts-deployment"]
    },
    "setup-contracts:staging": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile", "@vechain/vebetterdao-contracts#check-contracts-deployment:staging"]
    },
    "setup-contracts:testnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile", "@vechain/vebetterdao-contracts#check-contracts-deployment:testnet"]
    },
    "setup-contracts:mainnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile", "@vechain/vebetterdao-contracts#check-contracts-deployment:mainnet"]
    },
    "@repo/config#check-or-generate-local-config": {
      "cache": false
    },
    "@vechain/vebetterdao-contracts#check-contracts-deployment": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "@vechain/vebetterdao-contracts#check-contracts-deployment:staging": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "@vechain/vebetterdao-contracts#check-contracts-deployment:testnet": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "@vechain/vebetterdao-contracts#check-contracts-deployment:mainnet": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "@vechain/vebetterdao-contracts#simulation": {
      "cache": false,
      "dependsOn": ["^setup-contracts"]
    },
    "clean": {
      "cache": false
    },
    "compile": {
      "cache": true,
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": ["dist/**", "artifacts/**", "typechain-types/**", "cache/**"]
    },
    "compile:slither": {
      "cache": true,
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": ["dist/**", "artifacts/**", "typechain-types/**", "cache/**"]
    },
    "deploy": {
      "dependsOn": ["^deploy", "@repo/config#check-or-generate-local-config"]
    },
    "deploy:local": {
      "dependsOn": ["^deploy:local"]
    },
    "deploy:testnet-staging": {
      "dependsOn": ["^deploy:testnet-staging"]
    },
    "deploy:testnet": {
      "dependsOn": ["^deploy:testnet"]
    },
    "deploy:mainnet": {
      "dependsOn": ["^deploy:mainnet"]
    },
    "deploy:hardhat": {
      "dependsOn": ["^deploy:hardhat"]
    },
    "upgrade:contract": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": [],
      "cache": false
    },
    "upgrade:contract:local": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": [],
      "cache": false
    },
    "upgrade:contract:testnet": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": [],
      "cache": false
    },
    "upgrade:contract:testnet-staging": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": [],
      "cache": false
    },
    "upgrade:contract:mainnet": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": [],
      "cache": false
    },
    "deploy:contract": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": [],
      "cache": false
    },
    "deploy:contract:local": {
      "dependsOn": ["deploy:contract"]
    },
    "deploy:contract:testnet-staging": {
      "dependsOn": ["deploy:contract"]
    },
    "deploy:contract:testnet": {
      "dependsOn": ["deploy:contract"]
    },
    "deploy:contract:mainnet": {
      "dependsOn": ["deploy:contract"]
    },
    "call:contract": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "outputs": [],
      "cache": false
    },
    "call:contract:local": {
      "dependsOn": ["call:contract"]
    },
    "call:contract:testnet-staging": {
      "dependsOn": ["call:contract"]
    },
    "call:contract:testnet": {
      "dependsOn": ["call:contract"]
    },
    "call:contract:mainnet": {
      "dependsOn": ["call:contract"]
    },
    "start-round:testnet": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "cache": false
    },
    "start-round": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "cache": false
    },
    "get-galaxy-member-owners": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "cache": false
    },
    "get-galaxy-member-owners:staging": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "cache": false
    },
    "get-galaxy-member-selected-tokens": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "cache": false
    },
    "get-app-shares": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "cache": false
    },
    "test": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "test:watch": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "test:coverage:solidity": {
      "cache": false,
      "dependsOn": ["^@repo/config#check-or-generate-local-config"]
    },
    "test:thor-solo": {
      "cache": false
    },
    "test:hardhat": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "test:hardhat:shard": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "generate-galaxy-member-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "upload-galaxy-member-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "generate-creator-nft-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "generate-xapp-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "upload-xapp-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "upload-creator-nft-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "generate-docs": {
      "cache": false
    },
    "estimate-voting-gas:mainnet": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:fetch:local": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:fetch:testnet-staging": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:fetch:mainnet": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:simulate:local": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:simulate:testnet-staging": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:simulate:mainnet": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:seed:local": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:seed:testnet-staging": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:seed:mainnet": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:verify:local": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:verify:testnet-staging": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "endorsement-migration:verify:mainnet": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "stress:challenges:local": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    }
  }
}
