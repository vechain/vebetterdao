{
  "$schema": "https://turbo.build/schema.json",
  "globalDotEnv": [".env.dev", ".env.staging"],
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NEXT_PUBLIC_NETWORK_TYPE",
    "MNEMONIC", 
    "CONTRACTS_ADMIN_ADDRESS", 
    "B3TR_GOVERNOR_QUORUM_PERCENTAGE", 
    "B3TR_GOVERNOR_MIN_DELAY", 
    "B3TR_GOVERNOR_VOTING_PERIOD", 
    "B3TR_GOVERNOR_VOTING_DELAY", 
    "B3TR_GOVERNOR_PROPOSAL_THRESHOLD", 
    "VOTE_2_EARN_POOL_ADDRESS",
    "TREASURY_POOL_ADDRESS",
    "INITIAL_X_ALLOCATION",
    "INITIAL_VOTE_2_EARN_ALLOCATION",
    "INITIAL_TREASURY_ALLOCATION", 
    "EMISSIONS_CYCLE_DURATION",
    "EMISSIONS_X_ALLOCATION_DECAY_PERCENTAGE",
    "EMISSIONS_VOTE_2_EARN_DECAY_PERCENTAGE",
    "EMISSIONS_X_ALLOCATION_DECAY_PERIOD",
    "EMISSIONS_VOTE_2_EARN_ALLOCATION_DECAY_PERIOD",
    "EMISSIONS_TREASURY_PERCENTAGE",
    "EMISSIONS_MAX_VOTE_2_EARN_DECAY_PERCENTAGE",
    "X_ALLOCATION_POOL_BASE_ALLOCATION_PERCENTAGE",
    "X_ALLOCATION_POOL_APP_SHARES_MAX_CAP",
    "EMISSIONS_INITIAL_EMISSIONS"
  ],
  "pipeline": {
    "install": {
      "dependsOn": ["@repo/contracts#install", "^compile"]
    },
    "@repo/contracts#install": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "//#solo-up": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@repo/contracts#check-contracts-deployment"]
    },
    "dev:staging": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@repo/contracts#check-contracts-deployment"]
    },
    "@repo/config#check-or-generate-local-config": {
      "cache": false
    },

    "@repo/contracts#check-contracts-deployment": {
      "cache": false,
      "dependsOn": ["^compile", "//#solo-up", "@repo/config#check-or-generate-local-config"]
    },
    "clean": {
      "cache": false
    },
    "compile": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^deploy"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["@repo/contracts#check-contracts-deployment", "test:hardhat"]
    },
    "test:thor-solo": {
      "cache": false,
      "dependsOn": ["@repo/contracts#check-contracts-deployment"]
    },
    "test:hardhat": {
      "cache": false
    } 
  }
}
