{
  "$schema": "https://turbo.build/schema.json",
  "globalDotEnv": [".env"],
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["NEXT_PUBLIC_APP_ENV", "MNEMONIC", "NFT_STORAGE_KEY"],
  "pipeline": {
    "install": {
      "dependsOn": ["@repo/contracts#install", "^compile"]
    },
    "@repo/contracts#install": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "//#solo-up": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^setup-contracts"]
    },
    "dev:testnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^setup-contracts:testnet"]
    },
    "setup-contracts": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile", "@repo/contracts#check-contracts-deployment"]
    },
    "setup-contracts:testnet": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^compile", "@repo/contracts#check-contracts-deployment:testnet"]
    },
    "@repo/config#check-or-generate-local-config": {
      "cache": false,
      "dependsOn": ["^compile"]
    },
    "@repo/contracts#check-contracts-deployment": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "@repo/contracts#check-contracts-deployment:testnet": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config"]
    },
    "clean": {
      "cache": false
    },
    "compile": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^deploy"]
    },
    "deploy:testnet": {
      "dependsOn": ["^deploy:testnet"]
    },
    "start-round:testnet": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "cache": false
    },
    "start-round": {
      "dependsOn": ["@repo/config#check-or-generate-local-config"],
      "cache": false
    },
    "test": {
      "cache": false,
      "dependsOn": ["^compile", "@repo/config#check-or-generate-local-config", "test:hardhat"]
    },
    "test:thor-solo": {
      "cache": false
    },
    "test:hardhat": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "generate-b3tr-badge-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "upload-b3tr-badge-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "generate-xapp-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "upload-xapp-metadata": {
      "cache": false,
      "dependsOn": ["@repo/config#check-or-generate-local-config"]
    },
    "lambda:build": {
      "cache": false
    },
    "lambda:test": {
      "cache": false
    },
    "lambda:testrun": {
      "cache": false
    }
  }
}
