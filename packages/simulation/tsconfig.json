{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": true,
    "types": ["node", "hardhat"]
  },
  "include": ["src/**/*.ts", "hardhat.config.ts", "simulation.config.ts"]
}
