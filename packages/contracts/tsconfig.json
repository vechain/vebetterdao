{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": [
    "index.ts",
    "artifacts/contracts/**/*.json",
    "typechain-types/**/*.ts"
    // "scripts/**/*.ts" //TODO: Add this back after all the issues are fixed
    // "test/**/*.ts" //TODO: Add this back after all the issues are fixed
  ],
  "exclude": ["node_modules", "dist"]
}
