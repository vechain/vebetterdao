{
  "name": "@repo/contracts",
  "version": "1.0.0",
  "main": "main.ts",
  "types": "main.ts",
  "license": "MIT",
  "scripts": {
    "test": "npx hardhat test",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.ts",
