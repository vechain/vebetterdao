{
  "name": "@repo/contracts",
  "version": "0.0.1",
  "main": "index.ts",
  "types": "index.ts",
  "license": "MIT",
  "scripts": {
    "test:thor-solo": "npx hardhat test",
    "test:hardhat": "hardhat test --network hardhat",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy",
    "deploy:testnet": "npx hardhat run scripts/deploy --network vechain_testnet",
    "check-contracts-deployment": "npx hardhat run scripts/checkContractsDeployment.ts",
    "check-contracts-deployment:testnet": "npx hardhat run scripts/checkContractsDeployment.ts --network vechain_testnet",
    "generate-b3tr-badge-metadata": "npx hardhat run scripts/metadata/B3TRBadgeNFTs/generate.ts",
    "upload-b3tr-badge-metadata": "yarn generate-b3tr-badge-metadata && npx hardhat run scripts/metadata/B3TRBadgeNFTs/upload.ts",
    "generate-xapp-metadata": "npx hardhat run scripts/metadata/xApps/generate.ts",
    "upload-xapp-metadata": "yarn generate-xapp-metadata && npx hardhat run scripts/metadata/xApps/upload.ts",
    "start-round:testnet": "npx hardhat run scripts/emissions/startRound.ts --network vechain_testnet",
    "start-round": "npx hardhat run scripts/emissions/startRound.ts",
    "start-solo": "docker compose up -d",
    "stop-solo": "docker compose down",
    "clean": "rm -rf dist artifacts node_modules",
    "lint": "eslint . --ext .ts",
    "format": "eslint . --ext .ts --fix"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.2",
    "@nomicfoundation/hardhat-ethers": "^3.0.4",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.10",
    "@nomiclabs/hardhat-etherscan": "^3.0.0",
    "@nomiclabs/hardhat-truffle5": "^2.0.7",
    "@nomiclabs/hardhat-web3": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@openzeppelin/contracts-upgradeable": "^5.0.2",
    "@openzeppelin/upgrades-core": "^1.32.5",
    "@repo/config": "*",
    "@typechain/hardhat": "^8.0.0",
    "@types/chai": "^4.2.0",
    "@types/mocha": ">=9.1.0",
    "@vechain/hardhat-ethers": "^0.1.4",
    "@vechain/hardhat-vechain": "^0.1.4",
    "@vechain/web3-providers-connex": "^1.1.2",
    "chai": "^4.2.0",
    "dotenv": "^16.3.1",
    "hardhat": "^2.19.1",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.1",
    "ts-node": ">=8.0.0",
    "typechain": "^8.1.0",
    "typescript": ">=4.5.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^1.1.1",
    "@repo/eslint-config": "*",
    "@typechain/ethers-v6": "^0.4.3",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "ethers": "^6.9.0",
    "hardhat": "^2.19.1",
    "nft.storage": "^7.1.1",
    "prettier": "^3.2.4"
  }
}
