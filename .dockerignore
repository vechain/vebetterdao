# Dependencies (will be installed fresh in container)
node_modules
**/node_modules

# Git
.git
.gitignore

# Build outputs (will be generated in container)
.next
**/.next
dist
**/dist
.turbo
**/.turbo

# Contract artifacts (large, not needed for frontend)
packages/contracts/artifacts
packages/contracts/cache
packages/contracts/coverage
packages/contracts/typechain-types

# Test files (but keep packages/contracts/test/helpers which is needed for build)
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/tests
**/__tests__
**/__mocks__
**/coverage
**/.nyc_output
apps/**/test
packages/config/**/test
packages/constants/**/test
packages/eslint-config/**/test
packages/lambda/**/test
packages/typescript-config/**/test
packages/utils/**/test
# Note: packages/contracts/test is NOT excluded - build scripts depend on test/helpers

# Development files
.env
.env.*
!.env.example
*.log
*.md
!README.md

# IDE and editor
.vscode
.idea
*.swp
*.swo

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# CI/CD
.github
.husky

# Terraform
terraform

# Misc
*.tgz
*.tar.gz
.DS_Store
Thumbs.db
slither.config.json
sonar-project.properties
Makefile

